# --- Backend Configuration ---

# Database Connection
# For local development with Docker (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres:localpassword@localhost:5432/osteosarcoma_db
# For default local SQLite (no Docker required):
DATABASE_URL=sqlite+aiosqlite:///./ontex.db

# AI Services (Required for summarization features)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# Admin Dashboard Access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# App Settings
# Options: local, staging, production
ENVIRONMENT=local
# Set to 1 to skip auto-migrations on startup
SKIP_MIGRATIONS=0

# --- Frontend Configuration ---
# Base URL for the backend API (used by the frontend)
VITE_API_URL=http://localhost:8000/api/v1

# --- Docker Configuration (Optional) ---
# Only used if running via docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=osteosarcoma_db

# --- Clerk Authentication ---
# Get these from https://dashboard.clerk.com → API Keys.
# CLERK_SECRET_KEY is used for both JWT verification and for resolving the
# daily ingestion summary recipient list from Clerk users.
CLERK_JWKS_URL=
CLERK_SECRET_KEY=

# --- Email Notifications (Resend) ---
# Used by the daily ingestion pipeline to send summary emails.
# Leave RESEND_API_KEY empty to disable email notifications.
# Recipients are resolved from Clerk users who have opted in via the
# "Notifications" tab on their account (unsafeMetadata.emailIngestionSummary).
RESEND_API_KEY=
INGESTION_SUMMARY_FROM=noreply@ktn.dog
